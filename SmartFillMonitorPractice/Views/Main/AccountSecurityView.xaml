<UserControl x:Class="SmartFillMonitor.Views.Main.AccountSecurityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:extensions="clr-namespace:SmartFillMonitor.Extensions"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="760">
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="账户安全" Foreground="{StaticResource AppDanger}" FontSize="16" Margin="0,0,0,10"/>
                    <TextBlock Text="当前页面用于修改当前登录用户的密码。修改成功后需要重新登录。" Foreground="{StaticResource AppTextMuted}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding CurrentUserText}" Foreground="White" FontSize="14" Margin="0,0,0,20"/>

                    <TextBlock Text="当前密码" Foreground="White" Margin="0,0,0,6"/>
                    <Border Background="#1F2430" BorderBrush="#3E4C63" BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,0,2">
                        <PasswordBox x:Name="CurrentPasswordBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     CaretBrush="White"
                                     FontSize="14"
                                     Foreground="White"
                                     VerticalContentAlignment="Center"
                                     extensions:PasswordBoxExtension.BoundPassword="{Binding CurrentPassword, Mode=TwoWay}"
                                     extensions:PasswordBoxCapsLockExtension.HintTarget="{Binding ElementName=CurrentPasswordCapsLockHintTextBlock}"/>
                    </Border>
                    <TextBlock x:Name="CurrentPasswordCapsLockHintTextBlock"
                               Text="大写锁定已打开"
                               FontSize="11"
                               Foreground="#FFD166"
                               Margin="0,0,4,10"
                               HorizontalAlignment="Right"
                               Visibility="Hidden"/>

                    <TextBlock Text="新密码" Foreground="White" Margin="0,0,0,6"/>
                    <Border Background="#1F2430" BorderBrush="#3E4C63" BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,0,2">
                        <PasswordBox x:Name="NewPasswordBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     CaretBrush="White"
                                     FontSize="14"
                                     Foreground="White"
                                     VerticalContentAlignment="Center"
                                     extensions:PasswordBoxExtension.BoundPassword="{Binding NewPassword, Mode=TwoWay}"
                                     extensions:PasswordBoxCapsLockExtension.HintTarget="{Binding ElementName=NewPasswordCapsLockHintTextBlock}"/>
                    </Border>
                    <TextBlock x:Name="NewPasswordCapsLockHintTextBlock"
                               Text="大写锁定已打开"
                               FontSize="11"
                               Foreground="#FFD166"
                               Margin="0,0,4,10"
                               HorizontalAlignment="Right"
                               Visibility="Hidden"/>

                    <TextBlock Text="确认新密码" Foreground="White" Margin="0,0,0,6"/>
                    <Border Background="#1F2430" BorderBrush="#3E4C63" BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,0,2">
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     CaretBrush="White"
                                     FontSize="14"
                                     Foreground="White"
                                     VerticalContentAlignment="Center"
                                     extensions:PasswordBoxExtension.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay}"
                                     extensions:PasswordBoxCapsLockExtension.HintTarget="{Binding ElementName=ConfirmPasswordCapsLockHintTextBlock}"/>
                    </Border>
                    <TextBlock x:Name="ConfirmPasswordCapsLockHintTextBlock"
                               Text="大写锁定已打开"
                               FontSize="11"
                               Foreground="#FFD166"
                               Margin="0,0,4,14"
                               HorizontalAlignment="Right"
                               Visibility="Hidden"/>

                    <TextBlock Text="密码至少 10 位，并同时包含大写字母、小写字母和数字。" Foreground="{StaticResource AppTextMuted}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,18"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="确认修改"
                                Command="{Binding SaveCommand}"
                                Width="120"
                                Height="40"
                                Margin="0,0,10,0"/>
                        <Button Content="返回首页"
                                Command="{Binding CancelCommand}"
                                Width="120"
                                Height="40"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
