<UserControl x:Class="SmartFillMonitor.Views.Auth.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:extensions="clr-namespace:SmartFillMonitor.Extensions"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="600" d:DesignWidth="850" mc:Ignorable="d">

    <Border Background="{StaticResource DarkBg}"
            BorderBrush="#333" BorderThickness="1" CornerRadius="10">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="IsEnabled" Value="True" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                        <Setter Property="IsEnabled" Value="False" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="0" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="10,0,0,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#004e92" />
                        <GradientStop Offset="1" Color="#000428" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Margin="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Path Height="60"
                          Data="M10,20 L20,5 L30,20 L40,5 L50,20 L50,40 L10,40 Z"
                          Fill="White" Opacity="0.8" Stretch="Uniform" />
                    <TextBlock Margin="0,20,0,5" HorizontalAlignment="Center" FontSize="24"
                               Foreground="White" Text="SmartFill Monitor Practice" />
                    <TextBlock HorizontalAlignment="Center" FontSize="14"
                               Foreground="#AACCEE" Text="创建系统账户" />
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Background="{StaticResource CardBg}">
                <StackPanel Margin="40,20" VerticalAlignment="Center">
                    <TextBlock Margin="0,0,0,20" FontSize="22" FontWeight="Bold"
                               Foreground="White" Text="注册账户" />

                    <TextBlock Margin="0,0,0,12"
                               FontSize="12"
                               Foreground="#77C6FF"
                               Text="{Binding HintText}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,0,0,5" FontSize="14"
                               Foreground="{StaticResource TextDim}"
                               Text="用户类型" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <ComboBox x:Name="RoleComboBox" Padding="10,0"
                                  Background="Transparent" BorderThickness="0"
                                  DisplayMemberPath="Label" FontSize="14" Foreground="Black"
                                  ItemsSource="{Binding RoleOptions}"
                                  SelectedItem="{Binding SelectedRole, Mode=TwoWay}" />
                    </Border>

                    <TextBlock Margin="0,0,0,5" FontSize="14"
                               Foreground="{StaticResource TextDim}"
                               Text="用户名" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="UserNameTextBox" Padding="10,0"
                                 VerticalContentAlignment="Center" Background="Transparent"
                                 BorderThickness="0" FontSize="14" Foreground="White"
                                 Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>

                    <TextBlock Margin="0,0,0,5" FontSize="14"
                               Foreground="{StaticResource TextDim}"
                               Text="密码" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <PasswordBox x:Name="PasswordBox" Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     extensions:PasswordBoxCapsLockExtension.HintTarget="{Binding ElementName=PasswordCapsLockHintTextBlock}"
                                     extensions:PasswordBoxExtension.BoundPassword="{Binding Password, Mode=TwoWay}"
                                     Background="Transparent" BorderThickness="0"
                                     CaretBrush="White" FontSize="14" Foreground="White" />
                    </Border>

                    <TextBlock Margin="0,0,0,5" FontSize="14"
                               Foreground="{StaticResource TextDim}"
                               Text="确认密码" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <PasswordBox x:Name="ConfirmPasswordBox" Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     extensions:PasswordBoxCapsLockExtension.HintTarget="{Binding ElementName=ConfirmPasswordCapsLockHintTextBlock}"
                                     extensions:PasswordBoxExtension.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay}"
                                     Background="Transparent" BorderThickness="0"
                                     CaretBrush="White" FontSize="14" Foreground="White" />
                    </Border>
                    <TextBlock x:Name="ConfirmPasswordCapsLockHintTextBlock"
                               Margin="0,-8,4,8" HorizontalAlignment="Right" FontSize="11"
                               Foreground="#FFD166" Text="大写锁定已打开" Visibility="Hidden" />

                    <TextBlock Margin="0,2,0,14" FontSize="12"
                               Foreground="{StaticResource TextDim}"
                               Text="密码至少 10 位，并包含大写字母、小写字母和数字。" TextWrapping="Wrap" />

                    <Button Height="45"
                            Background="{StaticResource PrimaryBlue}"
                            Command="{Binding RegisterCommand}"
                            Content="注册" IsDefault="True"
                            Style="{StaticResource MordenBtnStyle}" />

                    <Button Height="40" Margin="0,10,0,0" Background="#3A3A4F"
                            Command="{Binding CancelCommand}"
                            Content="返回登录"
                            Style="{StaticResource MordenBtnStyle}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
